---
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
  heroPage?: boolean;
}

const {
  title = 'Centauri Lifting Club',
  description = 'Premium athletic wear for the dedicated. Centauri Lifting Club.',
  heroPage = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Centauri Lifting Club' ? title : `${title} — Centauri Lifting Club`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Navbar />
    <main class:list={[{ 'offset-nav': !heroPage }]}>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Cinzel "A" with crossbar removed via clip-path polygon.
     The polygon is an H-shape: full-width above/below the crossbar zone,
     narrow columns only at the crossbar height so the diagonals stay intact. */
  .lambda-a {
    display: inline-block;
    line-height: 1;
    /* Crossbar sits at ~42–51% of element height (Cinzel cap metrics + line-height:1).
       Diagonal strokes cross that zone at ~26% from left and ~74% from right. */
    clip-path: polygon(
      0% 0%, 100% 0%,
      100% 42%, 74% 42%, 74% 51%, 100% 51%,
      100% 100%, 0% 100%,
      0% 51%, 26% 51%, 26% 42%, 0% 42%
    );
  }

  :root {
    --black: #000;
    --white: #fff;
    --cream: #f5f0e8;
    --off-white: #fafaf8;
    --gray-light: #e8e8e4;
    --gray: #888;
    --nav-height: 56px;
    --font-brand: 'Cinzel', serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background: var(--white);
    color: var(--black);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  main.offset-nav {
    padding-top: var(--nav-height);
  }
</style>

---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="footer-inner">
    <a href={base} class="footer-brand">CENTAURI LIFTING CLUB</a>
    <nav class="footer-nav">
      <a href={`${base}about`} class="footer-link">ABOUT</a>
      <a href={`${base}clothing`} class="footer-link">EXPLORE</a>
      <a href={`${base}contact`} class="footer-link">CONTACT</a>
    </nav>
    <p class="footer-copy">© 2026 Centauri Lifting Club. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: #000;
    color: #fff;
    padding: 4rem 2rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .footer-brand {
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.28em;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer-brand:hover {
    opacity: 0.65;
  }

  .footer-nav {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .footer-link {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.28em;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: #fff;
  }

  .footer-copy {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 600px) {
    .footer-nav {
      gap: 2rem;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <div class="contact-page">

    <div class="contact-header">
      <h1 class="contact-title">CONTACT</h1>
      <p class="contact-sub">
        Questions about an order, a product, or just want to reach out?<br />
        Send us a message and we'll get back to you shortly.
      </p>
    </div>

    <div class="contact-divider"></div>

    <!-- Success message — shown by Formspree on submit -->
    <div data-fs-success class="form-success">
      Your message has been sent. We'll be in touch soon.
    </div>

    <!-- Form-level error banner -->
    <div data-fs-error class="form-error-banner"></div>

    <form class="contact-form" id="contact-form" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label for="first-name" class="form-label">FIRST NAME</label>
          <input
            type="text"
            id="first-name"
            name="first_name"
            class="form-input"
            required
            data-fs-field
          />
          <span data-fs-error="first_name" class="field-error"></span>
        </div>
        <div class="form-group">
          <label for="last-name" class="form-label">LAST NAME</label>
          <input
            type="text"
            id="last-name"
            name="last_name"
            class="form-input"
            required
            data-fs-field
          />
          <span data-fs-error="last_name" class="field-error"></span>
        </div>
      </div>

      <div class="form-group">
        <label for="email" class="form-label">EMAIL ADDRESS</label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          required
          data-fs-field
        />
        <span data-fs-error="email" class="field-error"></span>
      </div>

      <div class="form-group">
        <label for="subject" class="form-label">SUBJECT</label>
        <input
          type="text"
          id="subject"
          name="subject"
          class="form-input"
          data-fs-field
        />
        <span data-fs-error="subject" class="field-error"></span>
      </div>

      <div class="form-group">
        <label for="message" class="form-label">MESSAGE</label>
        <textarea
          id="message"
          name="message"
          class="form-input form-textarea"
          rows="6"
          required
          data-fs-field
        ></textarea>
        <span data-fs-error="message" class="field-error"></span>
      </div>

      <button type="submit" class="submit-btn" data-fs-submit-btn>
        SEND MESSAGE
      </button>
    </form>

  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.querySelector('[data-fs-success]') as HTMLElement;
  const formErrorEl = document.querySelector('[data-fs-error]:not([data-fs-error=""])') as HTMLElement;
  const submitBtn = form.querySelector('[data-fs-submit-btn]') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous errors
    formErrorEl.textContent = '';
    form.querySelectorAll('[data-fs-error][data-fs-error!=""]').forEach(el => (el as HTMLElement).textContent = '');
    form.querySelectorAll('[data-fs-field]').forEach(el => el.removeAttribute('aria-invalid'));

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'SENDING…';

    const data = new FormData(form);

    try {
      const res = await fetch('https://formspree.io/f/xzdlgonv', {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      const json = await res.json();

      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'block';
        return;
      }

      // Field / form errors from Formspree
      if (json.errors) {
        json.errors.forEach((err: { field?: string; message: string }) => {
          if (err.field) {
            const fieldEl = form.querySelector(`[data-fs-error="${err.field}"]`) as HTMLElement | null;
            if (fieldEl) fieldEl.textContent = err.message;
            const input = form.querySelector(`[name="${err.field}"]`);
            if (input) input.setAttribute('aria-invalid', 'true');
          } else {
            formErrorEl.textContent = err.message;
          }
        });
      } else {
        formErrorEl.textContent = json.error || 'Something went wrong. Please try again.';
      }
    } catch {
      formErrorEl.textContent = 'Network error. Please try again.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>

<style>
  .contact-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 5rem 2rem 8rem;
  }

  /* ── Header ── */
  .contact-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .contact-title {
    font-family: var(--font-brand);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 400;
    letter-spacing: 0.22em;
    margin-bottom: 1.5rem;
  }

  .contact-sub {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.9;
    letter-spacing: 0.04em;
    color: #666;
  }

  .contact-divider {
    height: 1px;
    background: var(--gray-light);
    margin-bottom: 3.5rem;
  }

  /* ── Success / error banners ── */
  [data-fs-success] {
    display: none;
    text-align: center;
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 0.06em;
    color: var(--gray);
    padding: 4rem 0;
    line-height: 1.9;
  }

  .form-error-banner:not(:empty) {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #c0392b;
    margin-bottom: 1.5rem;
  }

  /* ── Form layout ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* ── Labels ── */
  .form-label {
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.26em;
    color: var(--gray);
  }

  /* ── Inputs — underline style ── */
  .form-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--gray-light);
    padding: 0.6rem 0;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--black);
    outline: none;
    transition: border-color 0.2s;
    border-radius: 0;
    -webkit-appearance: none;
  }

  .form-input:focus {
    border-bottom-color: var(--black);
  }

  /* Formspree sets aria-invalid="true" on fields with errors */
  .form-input[aria-invalid='true'] {
    border-bottom-color: #c0392b;
  }

  .form-textarea {
    resize: none;
    line-height: 1.8;
  }

  /* ── Field-level errors ── */
  .field-error:not(:empty) {
    font-size: 10px;
    letter-spacing: 0.06em;
    color: #c0392b;
    margin-top: 0.25rem;
  }

  /* ── Submit ── */
  .submit-btn {
    align-self: flex-start;
    padding: 1rem 3.5rem;
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.26em;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .submit-btn:hover {
    opacity: 0.75;
  }

  /* Formspree disables the button during submission */
  .submit-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }

    .submit-btn {
      align-self: stretch;
      text-align: center;
    }
  }
</style>

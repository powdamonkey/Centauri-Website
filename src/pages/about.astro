---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" heroPage={true}>
  <!-- Hero video — same structure as home -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      poster="/images/about-poster.jpg"
    >
      <!-- Drop your about video at public/videos/about.mp4 -->
      <source src="/videos/about.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">CENTAURI LIFTING CLUB</p>
      <h1 class="hero-title">WE WERE MADE<br />FOR MORE</h1>
    </div>
  </section>

  <!-- Mission section -->
  <section class="section section-mission">
    <div class="section-inner section-inner--narrow">
      <p class="section-label">THE MISSION</p>
      <h2 class="section-heading">BEYOND THE GYM</h2>
      <p class="section-body">
        Alpha Centauri. 4.37 light-years away. The closest star system to our own —
        and the next great frontier of human ambition. We chose that name because it
        captures something true: the most meaningful things humanity has ever achieved
        were once considered unreachable.
      </p>
      <p class="section-body">
        Every century has its great endeavor. Ours is the stars. And the same qualities
        that will carry the first human beings into deep space are the same qualities
        forged under a barbell in a gym at 5 a.m. — unwavering belief, disciplined
        repetition, and the refusal to accept limits as permanent.
      </p>
    </div>
  </section>

  <div class="full-divider"></div>

  <!-- Values section -->
  <section class="section section-values">
    <div class="section-inner">
      <p class="section-label">THE VALUES</p>
      <div class="values-grid">
        <div class="value">
          <h3 class="value-name">BELIEF</h3>
          <p class="value-body">
            Every civilizational leap began with someone who believed before
            there was evidence to justify it. We carry that same conviction
            into every session.
          </p>
        </div>
        <div class="value">
          <h3 class="value-name">DISCIPLINE</h3>
          <p class="value-body">
            Not motivation — which comes and goes — but the systematic,
            daily commitment to the work. Rocketry is repetition.
            So is building the body.
          </p>
        </div>
        <div class="value">
          <h3 class="value-name">TRANSCENDENCE</h3>
          <p class="value-body">
            To go beyond what was previously possible. The body is the
            first frontier. Master it, and you begin to understand how
            far the human spirit can actually reach.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="full-divider"></div>

  <!-- Closing statement -->
  <section class="section section-closing">
    <div class="section-inner section-inner--narrow">
      <blockquote class="closing-quote">
        "The same hands that add a plate to the bar will one day reach
        toward the stars. Train accordingly."
      </blockquote>
      <p class="closing-sub">— CENTAURI LIFTING CLUB</p>
      <a href="/clothing" class="closing-cta">SHOP THE COLLECTION</a>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    height: 100vh;
    height: 100dvh;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-eyebrow {
    font-family: var(--font-brand);
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1.75rem;
    animation: fadeUp 1s ease 0.3s both;
  }

  .hero-title {
    font-family: var(--font-brand);
    font-size: clamp(34px, 6vw, 76px);
    font-weight: 400;
    letter-spacing: 0.18em;
    line-height: 1.14;
    animation: fadeUp 1s ease 0.55s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Shared section styles ── */
  .section {
    padding: 7rem 2rem;
  }

  .section-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-inner--narrow {
    max-width: 640px;
    text-align: center;
  }

  .section-label {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.35em;
    color: var(--gray);
    margin-bottom: 1.25rem;
  }

  .section-inner--narrow .section-label {
    display: block;
  }

  .section-heading {
    font-family: var(--font-brand);
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 400;
    letter-spacing: 0.2em;
    margin-bottom: 2.5rem;
  }

  .section-body {
    font-size: 14px;
    font-weight: 300;
    line-height: 2;
    letter-spacing: 0.03em;
    color: #444;
    margin-bottom: 1.5rem;
  }

  .section-body:last-of-type {
    margin-bottom: 0;
  }

  .full-divider {
    height: 1px;
    background: var(--gray-light);
    margin: 0 3rem;
  }

  /* ── Values ── */
  .section-values .section-label {
    text-align: center;
    display: block;
    margin-bottom: 3.5rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .value {
    text-align: center;
  }

  .value-name {
    font-family: var(--font-brand);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.22em;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--gray-light);
  }

  .value-body {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.9;
    letter-spacing: 0.02em;
    color: #555;
  }

  /* ── Closing ── */
  .closing-quote {
    font-family: var(--font-brand);
    font-size: clamp(16px, 2vw, 22px);
    font-weight: 400;
    letter-spacing: 0.06em;
    line-height: 1.65;
    font-style: italic;
    color: var(--black);
    margin-bottom: 1.5rem;
  }

  .closing-sub {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--gray);
    margin-bottom: 3rem;
  }

  .closing-cta {
    display: inline-block;
    padding: 0.9rem 3rem;
    background: var(--black);
    color: var(--white);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.26em;
    transition: opacity 0.2s;
  }

  .closing-cta:hover {
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .values-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .section {
      padding: 5rem 1.5rem;
    }

    .full-divider {
      margin: 0 1.5rem;
    }
  }
</style>
